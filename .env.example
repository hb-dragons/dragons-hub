# Database
DATABASE_URL=postgresql://dragons:dragons@localhost:5432/dragons

# API server
REDIS_URL=redis://localhost:6379
PORT=3001
NODE_ENV=development
LOG_LEVEL=debug                   # fatal, error, warn, info, debug, trace (default: info)

# Authentication (Better Auth)
BETTER_AUTH_SECRET=change-me-to-a-random-string-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3001

# Basketball-Bund SDK credentials
SDK_USERNAME=your-basketball-bund-username
SDK_PASSWORD=your-basketball-bund-password

# Web app
NEXT_PUBLIC_API_URL=http://localhost:3001
