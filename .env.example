# Database
DATABASE_URL=postgresql://dragons:dragons@localhost:5432/dragons

# API server
REDIS_URL=redis://localhost:6379
PORT=3001
NODE_ENV=development
LOG_LEVEL=debug                   # fatal, error, warn, info, debug, trace (default: info)
RUN_MODE=both                     # api, worker, both (default: both)

# Authentication (Better Auth)
BETTER_AUTH_SECRET=change-me-to-a-random-string-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3001

# Basketball-Bund SDK credentials
SDK_USERNAME=your-basketball-bund-username
SDK_PASSWORD=your-basketball-bund-password

# Google Cloud Storage (required for social features)
GCS_BUCKET_NAME=dragons-489109-social-assets
GCS_PROJECT_ID=dragons-489109

# Web app
NEXT_PUBLIC_API_URL=http://localhost:3001

# WhatsApp notifications (Meta Cloud API) — optional
# WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
# WHATSAPP_ACCESS_TOKEN=your-access-token

# Email notifications (SMTP) — optional
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@dragons.de
# SMTP_PASSWORD=your-password
# SMTP_FROM=Dragons <noreply@dragons.de>

# WAHA (WhatsApp HTTP API - for group notifications)
WAHA_BASE_URL=http://localhost:3002
WAHA_SESSION=default

# Referee SDK (separate federation account, optional)
# REFEREE_SDK_USERNAME=
# REFEREE_SDK_PASSWORD=

# Expo Push (optional — enables authenticated send tier with higher rate limits)
# Get token from https://expo.dev → account settings → access tokens
EXPO_ACCESS_TOKEN=
# Optional — used to validate that the EAS project ID matches between server and native
EXPO_PROJECT_ID=
