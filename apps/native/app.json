{
  "expo": {
    "name": "Dragons",
    "slug": "dragons",
    "scheme": "dragons",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "de.hbdragons.app",
      "supportsTablet": true,
      "infoPlist": {
        "NSFaceIDUsageDescription": "Use Face ID to unlock the Dragons app",
        "NSCameraUsageDescription": "Allow Dragons to access your camera for team photos",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "de.hbdragons.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#004b23"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "app.hbdragons.de"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "notification": {
      "icon": "./assets/notification-icon.png",
      "color": "#004b23"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      "expo-local-authentication",
      "expo-updates",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Dragons to access your camera for team photos.",
          "microphonePermission": false
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-logo.png",
          "backgroundColor": "#131313",
          "imageWidth": 240,
          "dark": {
            "image": "./assets/splash-logo.png",
            "backgroundColor": "#131313"
          }
        }
      ]
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/7b7481e3-ca0a-42dd-ba38-6a9169d6492d"
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7b7481e3-ca0a-42dd-ba38-6a9169d6492d"
      }
    },
    "owner": "eshamounskerto"
  }
}
