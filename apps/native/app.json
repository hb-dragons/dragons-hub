{
  "expo": {
    "name": "Dragons",
    "slug": "dragons",
    "scheme": "dragons",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "de.hbdragons.app",
      "supportsTablet": true,
      "infoPlist": {
        "NSFaceIDUsageDescription": "Use Face ID to unlock the Dragons app",
        "NSCameraUsageDescription": "Allow Dragons to access your camera for team photos"
      }
    },
    "android": {
      "package": "de.hbdragons.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#004b23"
      },
      "intentFilters": [{
        "action": "VIEW",
        "autoVerify": true,
        "data": [{ "scheme": "https", "host": "app.hbdragons.de" }],
        "category": ["BROWSABLE", "DEFAULT"]
      }]
    },
    "notification": {
      "icon": "./assets/notification-icon.png",
      "color": "#004b23"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      "expo-local-authentication",
      ["expo-camera", { "cameraPermission": "Allow Dragons to access your camera for team photos.", "microphonePermission": false }],
      ["expo-splash-screen", {
        "image": "./assets/splash-logo.png",
        "backgroundColor": "#131313",
        "imageWidth": 240,
        "dark": {
          "image": "./assets/splash-logo.png",
          "backgroundColor": "#131313"
        }
      }],
      "./plugins/remove-push-entitlement"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
