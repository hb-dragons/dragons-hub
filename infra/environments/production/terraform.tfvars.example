# Copy this file to terraform.tfvars and fill in your values
# DO NOT commit terraform.tfvars to version control

project_id     = "your-gcp-project-id"
project_number = "123456789012"
region         = "europe-west3"

# GitHub (for Workload Identity CI/CD)
github_org  = "your-github-org"
github_repo = "dragons-hub"

# Custom Domains
web_domain = "app.dragons.example.com"
api_domain = "api.dragons.example.com"

# Basketball-Bund SDK credentials
sdk_username = "your-sdk-username"
sdk_password = "your-sdk-password"

# Referee assignment SDK credentials (separate federation account)
referee_sdk_username = "your-referee-sdk-username"
referee_sdk_password = "your-referee-sdk-password"

# Stramatel scoreboard panel id. Must match the GitHub repo variable
# SCOREBOARD_DEVICE_ID (used as Docker build-arg for the web image) so the
# admin/overlay UI talks to the same device the API ingest is bound to.
scoreboard_device_id = "dragons-1"

# AI features (chatbot + rescheduling assistant + MCP)
# In CI these come from GitHub: vars.CHATBOT_ENABLED / vars.ASSISTANT_ENABLED
# (feature flags) and secrets.GOOGLE_GENERATIVE_AI_API_KEY / secrets.MCP_TOKEN,
# passed as TF_VAR_* by .github/workflows/opentofu.yml.
chatbot_enabled   = "false"
assistant_enabled = "false"

# Google AI Studio key — required (no default). Must be a real key when either
# feature flag is "true", or the API/Worker reject startup. Stored in Secret Manager.
google_generative_ai_api_key = "your-google-ai-studio-key"

# Bearer token for the /mcp endpoint — required (no default), min 32 chars.
mcp_token = "your-mcp-token-at-least-32-characters-long"
