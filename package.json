{
  "name": "dragons-all",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "turbo dev --parallel",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "coverage": "turbo coverage",
    "check:ai-slop": "node scripts/check-ai-slop.mjs",
    "check:i18n": "pnpm --filter @dragons/web i18n:check",
    "security:audit": "pnpm audit --audit-level=high",
    "clean": "turbo clean"
  },
  "devDependencies": {
    "turbo": "^2.8.12",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "overrides": {
      "replace>minimatch": "3.1.5",
      "@capacitor/cli@5>tar": "7.5.9",
      "@better-auth/core": "1.5.2"
    }
  }
}
